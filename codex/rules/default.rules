# Default low-risk policy for this repository.

prefix_rule(
  pattern = ["git", "reset", "--hard"],
  decision = "forbidden",
  justification = "Hard resets are forbidden. Use non-destructive Git inspection and explicit review instead.",
  match = ["git reset --hard HEAD"],
  not_match = ["git reset --soft HEAD~1"]
)

prefix_rule(
  pattern = ["git", "checkout", "--"],
  decision = "forbidden",
  justification = "Do not discard local changes with checkout --. Review and edit files intentionally.",
  match = ["git checkout -- README.md"],
  not_match = ["git checkout -b feature/os-foundation"]
)

prefix_rule(
  pattern = ["rm", "-rf"],
  decision = "forbidden",
  justification = "Recursive destructive deletes are blocked in this project.",
  match = ["rm -rf tmp"],
  not_match = ["rm notes.txt"]
)
